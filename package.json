{
  "name": "mindforge-root",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "cd desktop && npm run dev",
    "install": "npm run install:agent && npm run install:desktop",
    "install:agent": "cd agent && npm install",
    "install:desktop": "cd desktop && npm install",
    "build": "cd desktop && npm run build",
    "typecheck": "cd desktop && npm run typecheck",
    "lint": "cd desktop && npm run lint",
    "start": "cd desktop && npm run start",
    "build:win": "cd desktop && npm run build:win"
  }
}