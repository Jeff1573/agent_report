{
  "name": "mindforge-root",
  "private": true,
  "engines": { "node": ">=20 <21" },
  "scripts": {
    "dev": "npm --prefix desktop run dev",
    "build": "npm --prefix desktop run build",
    "typecheck": "npm --prefix desktop run typecheck",
    "lint": "npm --prefix desktop run lint",
    "start": "npm --prefix desktop run start",
    "build:win": "npm --prefix desktop run build:win",
    "win:clean": "if exist desktop\\node_modules rmdir /s /q desktop\\node_modules",
    "win:prep": "npm run win:clean && npm --prefix desktop ci",
    "win:dev": "npm run win:prep && npm --prefix desktop run dev",
    "win:build": "npm run win:prep && npm --prefix desktop run build",
    "win:build:win": "npm run win:prep && npm --prefix desktop run build:win"
    ,
    "bridge:dev": "bash scripts/wsl2win.sh dev",
    "bridge:start": "bash scripts/wsl2win.sh start",
    "bridge:build": "bash scripts/wsl2win.sh build",
    "bridge:build:win": "bash scripts/wsl2win.sh build:win"
  }
}
