{
  "name": "mindforge-root",
  "private": true,
  "engines": { "node": ">=20 <21" },
  "workspaces": [
    "packages/*",
    "desktop"
  ],
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "npm run dev -w ./desktop",
    "build": "npm run build -w ./desktop",
    "typecheck": "npm run typecheck -w ./desktop",
    "lint": "npm run lint -w ./desktop",
    "start": "npm run start -w ./desktop",
    "build:win": "npm run build:win -w ./desktop",
    "build:all": "npm run build --workspaces --if-present",
    "dev:all": "npm run dev --workspaces --if-present",
    "typecheck:all": "npm run typecheck --workspaces --if-present",
    "lint:all": "npm run lint --workspaces --if-present",
    "test:all": "npm run test --workspaces --if-present"
  }
}
