# 环境变量示例（请复制为 .env 并按需修改）
# 注意：切勿提交真实密钥到仓库；此文件仅为键名参考。

# OpenAI 兼容接口地址（示例为自建网关，需替换为你的 /v1 端点）
OPENAI_BASE_URL=

# 如果使用标准 Bearer 鉴权，填写 API Key；若走自定义请求头，可留空
OPENAI_API_KEY=

# 默认模型名称（例如：gpt-4o-mini / qwen2.5:latest / your-custom-model）
OPENAI_MODEL=

# 某些“兼容”端点不支持 stream_options；设为 false 可避免报错（与代码中 OPENAI_STREAM_USAGE 对应）
OPENAI_STREAM_USAGE=false

# 超时与重试
TIMEOUT_MS=20000
MAX_RETRIES=2

# 如供应商要求自定义鉴权头（非 Authorization: Bearer）
CUSTOM_AUTH_HEADER=
CUSTOM_AUTH_VALUE=

# （可选）日志相关配置
# LOG_LEVEL 可取：debug | info | warn | error（默认 info）
LOG_LEVEL=info
# LOG_DIR 日志目录（默认：./logs）
LOG_DIR=./logs
# LOG_COLOR 控制台彩色输出：auto | true | false（默认 auto）
LOG_COLOR=auto

# Tavily API Key（必填以启用 Tavily 工具）
TAVILY_API_KEY=

# -------------------------
# 内部检索（RAG）向量嵌入配置
# -------------------------
# 选择向量模型提供者：openai | gemini（默认 openai）。仅示例脚本 kb-retriever-demo.ts 使用。
KB_EMBED_PROVIDER=gemini
# 指定嵌入模型：
# - 当 provider=openai 时：如 text-embedding-3-small / text-embedding-3-large
# - 当 provider=gemini 时：如 embedding-001 / gemini-embedding-001
KB_EMBED_MODEL=

# Google / Gemini 鉴权（任选其一均可被识别）
GOOGLE_API_KEY=
GEMINI_API_KEY=

# -------------------------
# 本地 RAG 语料目录（绝对路径）
# -------------------------
# 例如：
# - Windows:  E:\\kb\\docs
# - macOS:    /Users/you/kb/docs
# - Linux:    /home/you/kb/docs
RAG_DATA_DIR=

# 强制工具调用用于调试（仅 demo 脚本支持）：
# - FORCE_TOOL_NAME=kb_search 强制要求模型调用该工具
# - FORCE_TOOL_CHOICE_STYLE=tool | function | string
#   * tool：{ type: 'tool', name }
#   * function：{ type: 'function', function: { name } }
#   * string：'required'（仅表示必须使用工具，无法指定名称）
FORCE_TOOL_NAME=
FORCE_TOOL_CHOICE_STYLE=tool

# -------------------------
# LangGraph Checkpointer（会话持久化）
# -------------------------
# 模式：memory | postgres（默认 memory）
CHECKPOINT_MODE=memory
# Postgres 连接串（当 CHECKPOINT_MODE=postgres 时必填）
CHECKPOINT_POSTGRES_URL=
# 兼容变量名（如果你已有 POSTGRES_URL，可不重复填写）
POSTGRES_URL=

# 线程 ID 兜底（CLI 未传入 --thread 时使用）
# 支持 THREAD_ID 或 LG_THREAD_ID 任一变量名
THREAD_ID=
LG_THREAD_ID=

# ----- Embedding 连接测试脚本（demo:embed）-----
# 用于验证 OpenAI 兼容端点或 Gemini 的嵌入：
# - OPENAI_BASE_URL / OPENAI_API_KEY / CUSTOM_AUTH_*
# - KB_EMBED_PROVIDER=openai|gemini
# - KB_EMBED_MODEL=text-embedding-3-small|text-embedding-004 等
# 运行：npm run demo:embed -w agent -- --provider openai --model text-embedding-3-small
# DEMO_EMBED_NOTE=1
