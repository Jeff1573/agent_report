{
  "name": "mindforge-agent",
  "version": "1.0.0",
  "description": "MindForge Agent - Electron + React 18 + TypeScript 应用（基于 electron-vite）",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "npx tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "npx tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "precheck": "node scripts/pre-dev-check.js",
    "generate:icons": "node scripts/generate-icons.js",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "dev:skip-check": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "agent": "file:../agent",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "antd": "5.27.4",
    "react-router-dom": "6.27.0",
    "highlight.js": "^11.11.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^1.0.2",
    "@electron-toolkit/eslint-config-ts": "^1.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@rushstack/eslint-patch": "^1.7.1",
    "@types/node": "^24.5.2",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "38.1.2",
    "electron-builder": "26.0.12",
    "electron-vite": "4.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.2.4",
    "sharp": "^0.34.4",
    "typescript": "^5.3.3",
    "vite": "7.1.6"
  },
  "overrides": {
    "esbuild": "0.25.10"
  }
}
