{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    // 禁用 TypeScript 的未使用变量检查，交由 ESLint 处理（警告级别）
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "index.ts",
    "config/**/*.ts",
    "llm/**/*.ts",
    "runtime/**/*.ts",
    "services/**/*.ts",
    "stream/**/*.ts",
    "tools/**/*.ts",
    "utils/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "build", "examples", "tests", "scripts"]
}

