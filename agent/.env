# 环境变量示例（请复制为 .env 并按需修改）
# 注意：切勿提交真实密钥到仓库；此文件仅为键名参考。

# OPENAI_BASE_URL：OpenAI 兼容接口地址（示例为自建网关，需替换为你的 /v1 端点）
# OPENAI_API_KEY：如果使用标准 Bearer 鉴权，填写 API Key；若走自定义请求头，可留空
# OPENAI_MODEL：默认模型名称（例如：gpt-4o-mini / qwen2.5:latest / your-custom-model）

# GLM
OPENAI_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
OPENAI_API_KEY="e3f2d7c94c5d4f23898fc6b2cdfac04c.tMMA5uCIxKSY68FF"
OPENAI_MODEL="glm-4.5-flash"

# 阿里百炼
# OPENAI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1/"
# OPENAI_API_KEY="sk-48236c3e43064d35b091764a5e0e0bec"
# OPENAI_MODEL="qwen-plus-2025-07-28"

# 魔搭社区
# OPENAI_BASE_URL="https://api-inference.modelscope.cn/v1"
# OPENAI_API_KEY="ms-5b443f8e-b5b1-4f05-88df-02492a238935"
# OPENAI_MODEL="Qwen/Qwen3-Coder-480B-A35B-Instruct"

# 某些“兼容”端点不支持 stream_options；设为 false 可避免报错（与代码中 OPENAI_STREAM_USAGE 对应）
OPENAI_STREAM_USAGE=false

# 超时与重试
TIMEOUT_MS=120000
MAX_RETRIES=2

# 如供应商要求自定义鉴权头（非 Authorization: Bearer）
CUSTOM_AUTH_HEADER=
CUSTOM_AUTH_VALUE=

# （可选）日志相关配置
# LOG_LEVEL 可取：debug | info | warn | error（默认 info）
LOG_LEVEL=info
# LOG_DIR 日志目录（默认：./logs）
LOG_DIR=./logs
# LOG_COLOR 控制台彩色输出：auto | true | false（默认 auto）
LOG_COLOR=auto

# Tavily API Key（必填以启用 Tavily 工具）
TAVILY_API_KEY="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"

# -------------------------
# 内部检索（RAG）向量嵌入配置
# -------------------------
# 选择向量模型提供者：openai | gemini（默认 openai）。仅示例脚本 kb-retriever-demo.ts 使用。
KB_EMBED_PROVIDER=gemini
# 指定嵌入模型：
# - 当 provider=openai 时：如 text-embedding-3-small / text-embedding-3-large
# - 当 provider=gemini 时：如 embedding-001 / gemini-embedding-001
KB_EMBED_MODEL=gemini-embedding-001

# Google / Gemini 鉴权（任选其一均可被识别）
GOOGLE_API_KEY=AIzaSyC6EsT9UalamgaMKyK_vfwvRBmuvhqTlyw
GEMINI_API_KEY=AIzaSyC6EsT9UalamgaMKyK_vfwvRBmuvhqTlyw

# 知识库根目录（必须，绝对路径；用于保存原始/处理后资源）
KB_STORAGE_ROOT=/Users/fj/.codex/rag-test
RAG_DATA_DIR=/Users/fj/.codex/rag-test
# windows
# KB_STORAGE_ROOT=C:\Users\Administrator\.codex\rag-test
# RAG_DATA_DIR=C:\Users\Administrator\.codex\rag-test


# 原始文件目录（可选；不配置时默认 <KB_STORAGE_ROOT>\raw）
KB_STORAGE_RAW_DIR=

# Chroma 数据库 HTTP 接入地址（必须，示例为本地 8000 端口）
CHROMA_URL=http://localhost:8000
KB_COLLECTION=kb_test_1758803023060

# RAG 上下文拼接最大字符数（建议 3500–4500；方案A基线 4000）
RAG_CTX_CHAR_LIMIT=4000

## RAG相关配置结束·

# -------------------------
# 客户端重排与集合名上锁（可选/测试参数）
# -------------------------
# 当后端不支持 MMR 时，启用客户端重排以获得更好的多样性/相关性
RERANK_ENABLED=true
# 客户端重排候选规模（先 similarity 取候选，再本地 MMR 选择）
RERANK_FETCHK=32
# 本地 MMR 折中系数（0~1），0.35 兼顾相关性与多样性
RERANK_LAMBDA=0.35
# 集合名白名单：逗号分隔；为空表示仅允许 KB_COLLECTION
KB_COLLECTION_WHITELIST=

# MCP JSON配置路径
MCP_CONFIG_PATH=C:\\Users\\Administrator\\.cursor\\test\\mcp.json
